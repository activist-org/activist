    "@vitest/coverage-v8": "4.1.9",
    "@vue/test-utils": "2.4.11",
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "axe-core": "4.12.1",
    "axe-html-reporter": "2.2.11",
    "cross-env": "10.1.0",
    "env-cmd": "11.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint-plugin-vue": "10.9.2",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
