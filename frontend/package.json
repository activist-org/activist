{
  "name": "activist",
  "private": true,
  "scripts": {
    "build": "nuxi build",
    "build:local": "env-cmd -f ../.env.dev nuxi build",
    "dev": "nuxi dev",
    "dev:local": "env-cmd -f ../.env.dev nuxi dev",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "postinstall": "nuxi prepare",
    "test": "vitest run --run",
    "test:local": "rm -rf blob-report && yarn test:local:desktop || true && yarn test:local:mobile || true && yarn test:local:merge",
    "test:local:desktop": "cross-env TEST_ENV=local PLAYWRIGHT_BLOB_OUTPUT_FILE=./blob-report/desktop.zip playwright test --project='Desktop Chrome' --reporter=blob",
    "test:local:mobile": "cross-env TEST_ENV=local PLAYWRIGHT_BLOB_OUTPUT_FILE=./blob-report/mobile.zip playwright test --project='Mobile Chrome' --reporter=blob",
    "test:local:merge": "cross-env PLAYWRIGHT_HTML_OPEN=never playwright merge-reports --reporter html,list,./test-e2e/reporters/execution-time-reporter.ts,./test-e2e/accessibility/axe-reporter.ts ./blob-report",
    "test:local:grep": "cross-env TEST_ENV=local playwright test --project='Desktop Chrome' --project='Mobile Chrome'",
    "test:e2e:auth-setup": "cross-env TEST_ENV=local playwright test test-e2e/specs/all/authentication/sign-in/sign-in-authentication.spec.ts --grep 'User can show and hide password' --reporter=list",
    "test:prod": "cross-env TEST_ENV=prod playwright test",
    "test:comprehensive": "cross-env TEST_ENV=local CI=false playwright test",
    "test:auth": "cross-env TEST_ENV=local playwright test --user-data-dir=./test-results/user-data",
    "test:auth:prod": "cross-env TEST_ENV=prod playwright test --user-data-dir=./test-results/user-data",
    "test:clean": "rm -rf ./test-results/user-data && cross-env TEST_ENV=local playwright test",
    "typecheck": "nuxi typecheck",
    "format": "yarn prettier . --check --config ../.prettierrc --ignore-path ../.prettierignore",
    "lint": "eslint .",
    "restart:imports": "rm -rf .nuxt && rm -rf node_modules && yarn install"
  },
  "devDependencies": {
    "@headlessui/vue": "1.7.23",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/eslint-config": "1.16.0",
    "@nuxt/icon": "2.2.5",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/color-mode": "4.0.1",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/i18n": "10.4.0",
    "@pinia/nuxt": "0.11.3",
    "@playwright/test": "1.61.1",
    "@testing-library/vue": "8.1.0",
    "@types/node": "26.1.0",
